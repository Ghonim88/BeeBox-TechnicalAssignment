# Copy to .env and adjust for your machine: cp .env.example .env
#
# --- Docker engine selection (portability) ---
# Terraform/Ansible talk to your local Docker daemon. Pick the line for your setup:
#   Colima:          unix://$HOME/.colima/default/docker.sock
#   Docker Desktop:  unix:///var/run/docker.sock
#   Native Linux:    unix:///var/run/docker.sock
# Leave unset to use your active docker context's default.
# DOCKER_HOST=unix:///var/run/docker.sock

# --- Load balancer ---
LB_PORT=8080
LB_HOSTNAME=ucpe.swisscom.com

# --- Database (used by Terraform vars and the Flask app) ---
DB_NAME=beebox
DB_USER=beebox
DB_PASSWORD=beebox_pw
DB_ROOT_PASSWORD=root_pw
DB_HOST=db
DB_PORT=3306
